rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to get user's data from Firestore
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSystemAdmin() {
      return request.auth != null && request.auth.token.email == "jonathan@waterman.work";
    }

    // Corps Logos
    match /corps_logos/{logoFile} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Exchange Inventory Images (Matches: corps/{corpsId}/exchange/{fileName})
    match /corps/{corpsId}/exchange/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        getUserData().isAdmin == true &&
        getUserData().corpsId == corpsId;
    }
    
    // Default fallback for other files
    match /{allPaths=**} {
      allow read, write: if isSystemAdmin();
    }
  }
}
